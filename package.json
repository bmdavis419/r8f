{
  "name": "r8f",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo --ui=tui dev --parallel",
    "dev:mobile": "turbo --ui=tui -F mobile dev",
    "dev:api": "turbo --ui=tui -F api dev",
    "check": "turbo check",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "turbo": "^2.5.8"
  }
}
